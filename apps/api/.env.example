# ─────────────────────────────────────────
# SERVIDOR
# ─────────────────────────────────────────
PORT=3001                        # Puerto donde corre la API
NODE_ENV=development             # development | production | test
CORS_ORIGIN=http://localhost:3000  # URL del frontend permitido

# ─────────────────────────────────────────
# JWT / AUTENTICACIÓN
# ─────────────────────────────────────────
JWT_SECRET=                      # Clave secreta para firmar tokens (mín. 32 caracteres)
JWT_EXPIRES_IN=3600s             # Expiración del access token (ej: 3600s, 15m, 1h)
JWT_REFRESH_SECRET=              # Clave secreta para refresh tokens (diferente al JWT_SECRET)
JWT_REFRESH_EXPIRES_IN=30d       # Expiración del refresh token

# ─────────────────────────────────────────
# FIREBASE ADMIN SDK
# Obtener en: Firebase Console → Configuración → Cuentas de servicio → Generar clave
# ─────────────────────────────────────────
FIREBASE_PROJECT_ID=             # ID del proyecto Firebase (ej: mi-app-12345)
FIREBASE_CLIENT_EMAIL=           # Email de la cuenta de servicio
FIREBASE_PRIVATE_KEY=            # Clave privada (incluir las líneas \n tal cual)

# ─────────────────────────────────────────
# RPC PROVIDERS
# ─────────────────────────────────────────
HELIUS_API_KEY=                  # API Key de Helius (https://helius.dev)
HELIUS_RPC_URL=                  # URL RPC de Helius para Solana
ALCHEMY_BTC_URL=                 # URL RPC de Alchemy para Bitcoin
ALCHEMY_BNB_URL=                 # URL RPC de Alchemy para BNB Chain

# ─────────────────────────────────────────
# WEBHOOKS
# Secrets para verificar firma HMAC de cada proveedor
# ─────────────────────────────────────────
HELIUS_WEBHOOK_SECRET=           # Secret configurado en el dashboard de Helius
QUICKNODE_WEBHOOK_SECRET=        # Secret configurado en el dashboard de QuickNode

# ─────────────────────────────────────────
# PRECIO / MÉTRICAS
# ─────────────────────────────────────────
COINGECKO_API_KEY=               # API Key de CoinGecko (https://coingecko.com/api)
COINSTATS_API_KEY=               # API Key de CoinStats (https://coinstats.app)